	(text "V_T = 3.3V\nR1 is variable\nR2 = 50 ohms\nV_OUT = 3.3 * (50 / (50 + R1))\nV_OUT = 165 / (50 + R1)\n\n\n"
		(exclude_from_sim no)
		(at 221.234 48.26 0)
